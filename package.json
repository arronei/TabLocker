{
  "name": "tablocker",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-browser extension that locks a tab to a home page and tracks that tab's browsing history from that point.",
  "repository": "https://github.com/arronei/TabLocker.git",
  "author": "Arron Eicholz <arronei@me.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && stylelint \"src/**/*.css\"",
    "lint:ext": "web-ext lint --source-dir dist/firefox",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.10.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "stylelint": "^17.14.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "web-ext": "^10.5.0"
  }
}
