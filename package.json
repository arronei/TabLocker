{
  "author": "Arron Eicholz <arronei@me.com>",
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  },
  "description": "Cross-browser extension that locks a tab to a home page and tracks that tab's browsing history from that point.",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "c8": "^12.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-headers": "^1.3.4",
    "eslint-plugin-jsonc": "^3.3.0",
    "eslint-plugin-perfectionist": "^5.10.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "stylelint": "^17.14.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "web-ext": "^10.5.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "name": "tablocker",
  "private": true,
  "repository": "https://github.com/arronei/TabLocker.git",
  "scripts": {
    "build": "node build.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . && stylelint \"src/**/*.css\"",
    "lint:ext": "web-ext lint --source-dir dist/firefox",
    "pretest:e2e": "yarn build",
    "test:e2e": "playwright test",
    "test:unit": "node --experimental-strip-types --test \"src/**/*.test.ts\"",
    "test:unit:coverage": "c8 --reporter=lcov --reporter=text yarn test:unit",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "version": "1.0.0"
}
